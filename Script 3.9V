appBtn.Name = "AppIcon"; appBtn.Size = UDim2.new(0, 45, 0, 45); appBtn.Position = UDim2.new(0, 20, 0.5, -22)
appBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25); appBtn.Text = ""; appBtn.BorderSizePixel = 0
appBtn.ClipsDescendants = true; appBtn.Active = true 
