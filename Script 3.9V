    if v.Name:find("Zmey") then v:Destroy() end
end

-- Папка для путей
local pathFolder = workspace:FindFirstChild("ZmeyPathFolder") or Instance.new("Folder", workspace)
pathFolder.Name = "ZmeyPathFolder"

local function clearPathVisuals()
    pathFolder:ClearAllChildren()
end

_G.Config = {Bot = false, TP = false, ESP = false, Scale = 1, Eggs = 0}

